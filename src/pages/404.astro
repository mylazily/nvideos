---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';

export const prerender = true;
---

<Layout
  title="页面未找到 - 404"
  description="您访问的页面不存在"
  noindex={true}
>
  <main class="max-w-screen-xl mx-auto px-4 pt-20 pb-16 text-center">
    <h1 class="text-4xl font-bold text-gray-800 mb-4">404</h1>
    <p class="text-gray-600 mb-8">页面未找到</p>
    <a href="/" class="px-6 py-3 bg-pink-500 text-white rounded-lg text-sm hover:bg-pink-600 transition-colors">
      返回首页
    </a>
  </main>
  <BottomNav />
</Layout>
